generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MessageRole {
  user
  assistant
}

enum CaseStatus {
  draft
  curated
  artifact_complete
  ready_for_projection
  archived
}

enum CaseReviewStatus {
  pending
  human_reviewed
  approved
  rejected
}

enum ProjectionStatus {
  not_started
  previewed
  projected
}

enum ArtifactType {
  ideal_search_query
  ideal_answer
  expected_route
  expected_tool
  relevant_context
  memory_write_decision
  policy_flags
  extracted_slots
  state_assumptions
}

enum TaskType {
  write_query
  rag_reply
  routing
  tool_selection
  memory_write_decision
  custom
}

enum DerivedExampleStatus {
  draft
  generated
  human_reviewed
  approved
  rejected
  exported
}

enum GenerationMode {
  manual
  assisted
}

enum RelationType {
  precedes
  depends_on
  derived_from_same_case
}

enum DatasetFormat {
  dspy_jsonl
}

enum DatasetExampleReviewStatus {
  draft
  approved
  rejected
  exported
}

enum DatasetFieldSide {
  input
  output
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  createdAt   DateTime  @default(now())
  sessions    Session[]
  cases       Case[]
  sourceSlices SourceSlice[]
}

model LlmConfiguration {
  id          String   @id @default(cuid())
  name        String
  chatModel   String
  chatBaseUrl String?
  chatApiKey  String?
  systemPrompt String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

model RagConfiguration {
  id               String   @id @default(cuid())
  name             String
  qdrantBaseUrl    String
  qdrantApiKey     String?
  collectionName   String
  vectorName       String?
  queryModel       String?
  embeddingBaseUrl String?
  embeddingApiKey  String?
  embeddingModel   String?
  payloadPath      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
}

model SessionTag {
  id          String             @id @default(cuid())
  name        String             @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  sessions    SessionTagOnSession[]

  @@index([createdAt])
}

model Session {
  id        String    @id @default(cuid())
  projectId String
  title     String?
  curationNotes String?
  systemPrompt String?
  chatModel String?
  chatBaseUrl String?
  chatApiKey String?
  chatConnectionCheckedAt DateTime?
  chatConnectionVerifiedAt DateTime?
  chatConnectionError String?
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  cases     Case[]
  sourceSlices SourceSlice[]
  tags      SessionTagOnSession[]

  @@index([projectId, createdAt])
}

model SessionTagOnSession {
  sessionId String
  tagId     String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tag       SessionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([sessionId, tagId])
  @@index([tagId, createdAt])
}

model Message {
  id           String      @id @default(cuid())
  sessionId    String
  role         MessageRole
  text         String
  orderIndex   Int
  createdAt    DateTime    @default(now())
  metadataJson Json?
  session      Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, orderIndex])
  @@index([sessionId, createdAt])
}

model Case {
  id                String           @id @default(cuid())
  projectId         String
  sessionId         String
  title             String?
  conversationSliceJson Json
  sourceContextJson Json?
  selectedTurnIdsJson Json?
  sourceSummary     String           @default("")
  lastUserMessage   String
  labelsJson        Json?
  artifactsJson     Json?
  notes             String           @default("")
  interpretationJson Json?
  sourceMetadataJson Json?
  taskCandidatesJson Json?
  projectionStatus  ProjectionStatus @default(not_started)
  reviewStatus      CaseReviewStatus @default(pending)
  status            CaseStatus       @default(draft)
  createdBy         String           @default("human")
  updatedBy         String           @default("human")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session           Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  artifacts         CaseArtifact[]
  derivedExamples   DerivedExample[]

  @@index([projectId, status])
  @@index([projectId, reviewStatus])
  @@index([sessionId, createdAt])
}

model CaseArtifact {
  id             String       @id @default(cuid())
  caseId         String
  type           ArtifactType
  valueJson      Json
  notes          String?
  confidence     Float?
  provenanceJson Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  case           Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, type])
}

model TaskSpec {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  description         String
  taskType            TaskType
  inputSchemaJson     Json
  outputSchemaJson    Json
  requiredArtifactsJson Json
  optionalArtifactsJson Json
  validationRulesJson Json
  exportShapeJson     Json
  isActive            Boolean      @default(true)
  version             Int          @default(1)
  createdBy           String       @default("system")
  updatedBy           String       @default("system")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  derivedExamples     DerivedExample[]

  @@index([isActive, slug])
}

model DerivedExample {
  id                 String               @id @default(cuid())
  caseId             String
  taskSpecId         String
  title              String?
  inputPayloadJson   Json
  outputPayloadJson  Json
  generationMode     GenerationMode
  reviewStatus       DerivedExampleStatus @default(draft)
  validationStateJson Json
  provenanceJson     Json
  version            Int                  @default(1)
  createdBy          String               @default("human")
  updatedBy          String               @default("human")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  case               Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  taskSpec           TaskSpec             @relation(fields: [taskSpecId], references: [id], onDelete: Cascade)
  outgoingRelations  ProjectionRelation[] @relation("ProjectionRelationFrom")
  incomingRelations  ProjectionRelation[] @relation("ProjectionRelationTo")

  @@index([caseId, reviewStatus])
  @@index([taskSpecId, reviewStatus])
}

model ProjectionRelation {
  id                   String         @id @default(cuid())
  fromDerivedExampleId String
  toDerivedExampleId   String
  relationType         RelationType
  notes                String?
  createdAt            DateTime       @default(now())
  fromDerivedExample   DerivedExample @relation("ProjectionRelationFrom", fields: [fromDerivedExampleId], references: [id], onDelete: Cascade)
  toDerivedExample     DerivedExample @relation("ProjectionRelationTo", fields: [toDerivedExampleId], references: [id], onDelete: Cascade)

  @@index([fromDerivedExampleId, relationType])
  @@index([toDerivedExampleId, relationType])
}

model SourceSlice {
  id                    String           @id @default(cuid())
  projectId             String
  sessionId             String
  title                 String?
  conversationSliceJson Json
  surroundingContextJson Json
  selectedTurnIdsJson   Json
  lastUserMessage       String
  sourceSummary         String           @default("")
  sourceMetadataJson    Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session               Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  datasetExamples       DatasetExample[]

  @@index([projectId, createdAt])
  @@index([sessionId, updatedAt])
}

model DatasetSpec {
  id                String        @id @default(cuid())
  name              String
  slug              String        @unique
  description       String        @default("")
  datasetFormat     DatasetFormat @default(dspy_jsonl)
  inputSchemaJson   Json
  outputSchemaJson  Json
  mappingHintsJson  Json
  validationRulesJson Json
  exportConfigJson  Json
  isActive          Boolean       @default(true)
  version           Int           @default(1)
  createdBy         String        @default("system")
  updatedBy         String        @default("system")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  datasetExamples   DatasetExample[]

  @@index([isActive, slug])
}

model DatasetExample {
  id                  String                     @id @default(cuid())
  sourceSliceId       String
  datasetSpecId       String
  title               String?
  inputPayloadJson    Json
  outputPayloadJson   Json
  validationStateJson Json
  provenanceJson      Json
  reviewStatus        DatasetExampleReviewStatus @default(draft)
  version             Int                        @default(1)
  createdBy           String                     @default("human")
  updatedBy           String                     @default("human")
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  sourceSlice         SourceSlice                @relation(fields: [sourceSliceId], references: [id], onDelete: Cascade)
  datasetSpec         DatasetSpec                @relation(fields: [datasetSpecId], references: [id], onDelete: Cascade)
  fieldMappings       DatasetFieldMapping[]

  @@index([sourceSliceId, reviewStatus])
  @@index([datasetSpecId, reviewStatus])
}

model DatasetFieldMapping {
  id                 String           @id @default(cuid())
  datasetExampleId   String
  side               DatasetFieldSide
  fieldKey           String
  sourceKey          String
  sourcePath         String?
  transformChainJson Json
  constantValueJson  Json?
  manualValueJson    Json?
  llmConfigurationId String?
  llmPromptText      String?
  llmGeneratedValueJson Json?
  llmGenerationMetaJson Json?
  ragConfigurationId String?
  ragPromptText      String?
  ragGeneratedValueJson Json?
  ragGenerationMetaJson Json?
  resolvedPreviewJson Json?
  position           Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  datasetExample     DatasetExample   @relation(fields: [datasetExampleId], references: [id], onDelete: Cascade)

  @@unique([datasetExampleId, side, fieldKey])
  @@index([datasetExampleId, side])
}
